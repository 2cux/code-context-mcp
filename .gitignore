# CodeContext MCP Local Data
# =============================================================================
# Local data generated by the MCP server or CLI.
# These files may contain project code, logs, command output, compressed context,
# original content, receipts, or memory records, so they should not be committed.

.code-context-mcp/
~/.code-context-mcp/

# Harness Run Data
# =============================================================================
# Run execution records and harness configuration generated by the harness
# framework. These contain run receipts, checkpoints, and artifacts.

runs/
runs-*/
.harness/

# Allow example runs for documentation purposes.
!examples/runs/
!examples/runs/**/README.md

context/
.context/
context-cache/
.context-cache/


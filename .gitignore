# =============================================================================
# Fixtures That May Contain Large or Sensitive Data
# =============================================================================
# Keep this section conservative. Commit small, sanitized fixtures only.

fixtures/private/
fixtures/local/
fixtures/tmp/
fixtures/generated/
fixtures/**/*.local.*
fixtures/**/*.secret.*

# =============================================================================
# Evaluation Fixtures
# =============================================================================
# Large fixture files stay local; only small samples and README are committed.

fixtures/evaluation/**/*.log
fixtures/evaluation/**/*.json
fixtures/evaluation/**/*.txt
fixtures/evaluation/**/*.md
!fixtures/evaluation/**/README.md
!fixtures/evaluation/**/*.sample.*
!fixtures/evaluation/**/*.example.*
!fixtures/evaluation/**/.gitkeep

# =============================================================================
# MCP Eval Fixtures — committed for CI reproducibility
# =============================================================================

!fixtures/mcp-eval/
!fixtures/mcp-eval/**

# =============================================================================
# Performance Reports — committed output
# =============================================================================

!reports/performance/
!reports/performance/**/*.json
!reports/performance/**/*.jsonl
!reports/performance/**/*.md



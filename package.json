{
  "name": "code-context-mcp",
  "version": "0.2.0-beta",
  "description": "Local-first MCP server for AI coding agents — context compression and project-scoped memory",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "code-context": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "docs/",
    "README.md",
    "CLAUDE.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "cli": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "schema:migrate": "node dist/storage/migrations.js",
    "clean": "rm -rf dist/",
    "prebuild": "npm run clean",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "context",
    "compression",
    "memory",
    "ai-coding-agent",
    "claude-code",
    "cursor",
    "local-first"
  ],
  "author": "2cux",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/2cux/code-context-mcp"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "sql.js": "^1.12.0",
    "tiktoken": "^1.0.17"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/sql.js": "^1.4.11",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
